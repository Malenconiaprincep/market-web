# 复制为 .env.local 并填写（勿提交 .env.local）
# 以下变量仅在 Next.js 服务端可用（API Route），不要加 NEXT_PUBLIC_ 前缀，避免 Secret 暴露到浏览器。

# 飞书自建应用
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 多维表格（同一 Base 的 app_token 相同；URL：.../base/<app_token>?table=<table_id>）
FEISHU_BITABLE_APP_TOKEN=
# 情绪记录表 table_id（列名：涨停数、跌停数、情绪温度、情绪结论、空间龙、空间龙连板；可选「日期」）
FEISHU_BITABLE_TABLE_ID=
# 涨停数据表 table_id（建议增加「日期」列与情绪表对齐，便于按交易日筛选；列名：日期、股票代码、股票名称、所属行业…）
# FEISHU_BITABLE_TABLE_ID_ZT=

# 可选：手动覆盖 field_id → 内部字段名（JSON）。一般留空即可，服务端会按中文列名自动映射
# FEISHU_BITABLE_FIELD_MAP=

# 强制使用本地 Mock（不请求飞书）
# FEISHU_USE_MOCK=true

# —— market-skills（FastAPI：uvicorn main:app）
#   cd market-skills && uvicorn main:app --host 0.0.0.0 --port 8787
# 提供：/api/realtime、/api/history、/api/intraday、/api/limit_up、/api/limit_down 等
# 勿填 http://localhost:3000（Next 本机端口）；代理会请求 {BASE}/api/*，填错会 404
MARKET_SKILLS_API_BASE=http://127.0.0.1:8787
# 与 market-skills 的 INTRADAY_API_SECRET 或 CRON_SECRET 一致（对方未设置 Secret 时可留空）
# MARKET_SKILLS_API_SECRET=
