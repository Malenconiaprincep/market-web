# 以下变量仅在 Next.js 服务端可用（API Route），不要加 NEXT_PUBLIC_ 前缀，避免 Secret 暴露到浏览器。

# 飞书自建应用
FEISHU_APP_ID=cli_a93d05ffadb8dcee
FEISHU_APP_SECRET=pqPv04bm62HD82aQ9CJsogjfg3qhBVvs

# 多维表格：浏览器打开表格，URL 中的 app_token；数据表 ID 在表设置中查看
FEISHU_BITABLE_APP_TOKEN=I5VPbZaM7anuKjsebV6cmXKrnld
FEISHU_BITABLE_TABLE_ID=tblk1o0UqQB9ardh

FEISHU_BITABLE_TABLE_ID_ZT=tblMqGotfPsvRwQI

# 可选：列 field_id → 业务字段名 JSON，例如 {"fldxxxxx":"date","fldyyyyy":"temperature"}
